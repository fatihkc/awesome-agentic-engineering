{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "awesome-agentic-engineering",
  "compatibility_date": "2026-07-18",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "npm ci && npm run build"
  }
}
